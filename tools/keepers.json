  "8759c8a437d1bfc1": {
    "id": "8759c8a437d1bfc1",
    "type": "function",
    "z": "ae42528ac326c82b",
    "name": "function 114",
    "func": "var state = flow.get(\"feedback1.state\") || 0;\nif (msg.topic == \"binary_sensor.train_prox_1_sensor_2\") {\n    if (msg.payload) {\n        state = state + 2;\n    } else {\n        state = Math.abs(state - 2);\n    }\n    flow.set(\"feedback1.state\", state)\n} else if (msg.topic == \"binary_sensor.train_prox_1_sensor_1\") {\n    if (msg.payload) {\n        state = state + 1;\n    } else {\n        state = Math.abs(state - 1);\n    }\n    flow.set(\"feedback1.state\", state)\n}\n\nvar newpay = '<EVENT 200>\\n'\n    + '200 state[0x' + state + ']\\n'\n    + '<END 0 (OK)>\\n';\n    \nmsg.payload = {};\nmsg.data = {};\nmsg.payload = newpay;\n\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "// Code added here will be run once\n// whenever the node is started.\nflow.set(\"feedback1.state\", 0);",
    "finalize": "// Code added here will be run when the\n// node is being stopped or re-deployed.\nflow.set(\"feedback1.state\", 0);",
